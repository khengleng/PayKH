{
    "name": "paykh/sdk-php",
    "description": "Official PHP SDK for the PayKH Bakong KHQR payment gateway",
    "type": "library",
    "license": "Apache-2.0",
    "keywords": ["paykh", "bakong", "khqr", "payments", "cambodia"],
    "homepage": "https://paykh.cambobia.com",
    "require": {
        "php": ">=8.0",
        "ext-curl": "*",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5 || ^10.0"
    },
    "autoload": {
        "psr-4": {
            "PayKH\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PayKH\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "config": {
        "sort-packages": true
    }
}
