// PayKH data model.
//
// Phase 1 actively uses: User, Organization, OrganizationMember, Store,
// StoreBranding, ApiKey, Payment, PaymentStatusHistory,
// PaymentProviderReference, IdempotencyRecord, ProviderCredential, AuditLog,
// SecurityEvent.
//
// Webhook*, Plan, Subscription, UsageRecord, Invoice are defined here so the
// schema is forward-compatible (Phase 2/3 wires up the behavior) — this avoids
// a disruptive migration later. See ASSUMPTIONS.md.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum KeyMode {
  TEST
  LIVE
}

enum Currency {
  USD
  KHR
}

enum MemberRole {
  OWNER
  DEVELOPER
  ANALYST
  PLATFORM_ADMIN
}

enum PaymentStatus {
  PENDING
  SCANNED
  PAID
  EXPIRED
  FAILED
  CANCELLED
  REFUNDED
}

enum OrgStatus {
  ACTIVE
  SUSPENDED
}

enum WebhookDeliveryStatus {
  PENDING
  SUCCEEDED
  FAILED
}

enum RefundStatus {
  PENDING
  SUCCEEDED
  FAILED
}

enum SettlementStatus {
  PENDING
  SETTLED
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
}

enum VerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REJECTED
}

enum PointsTxnType {
  EARN
  REDEEM
  ADJUST
  EXPIRE
}

enum RedemptionStatus {
  ISSUED
  FULFILLED
  CANCELLED
  EXPIRED
}

enum PromotionType {
  POINTS_MULTIPLIER
  BONUS_POINTS
}

enum PromotionStatus {
  DRAFT
  ACTIVE
  PAUSED
  ENDED
}

enum ReferralStatus {
  PENDING
  QUALIFIED
  REWARDED
}

enum GameType {
  SCRATCH_CARD
  SPIN_WHEEL
  LUCKY_DRAW
}

enum PrizeType {
  NONE // "better luck next time"
  POINTS
  REWARD // grants a loyalty Reward (voucher)
  CUSTOM // merchant fulfils out-of-band
}

enum GamePlayStatus {
  ISSUED // entitlement granted, not yet revealed (scratch cards)
  REVEALED // outcome drawn
}

enum NotificationChannelType {
  WHATSAPP
  SMS
  SIGNAL
}

enum RiskCaseStatus {
  OPEN
  INVESTIGATING
  RESOLVED
  ESCALATED
}

enum ConnectorType {
  SLACK
  ZAPIER
  WEBHOOK
}

enum LedgerAccountType {
  ASSET
  LIABILITY
  REVENUE
  EXPENSE
  EQUITY
}

enum LedgerDirection {
  DEBIT
  CREDIT
}

// ---------------------------------------------------------------------------
// Identity & organizations
// ---------------------------------------------------------------------------

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  passwordHash    String? // null when only using Google OAuth (Phase 2)
  name            String?
  googleId        String?  @unique
  mfaEnabled      Boolean  @default(false)
  mfaSecret       String? // AES-GCM-encrypted TOTP secret (null until enrolled)
  isPlatformAdmin Boolean  @default(false) // global platform operator
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  memberships OrganizationMember[]
  auditLogs   AuditLog[]
}

model Organization {
  id         String    @id
  name       String
  status     OrgStatus @default(ACTIVE)
  planId     String?
  graceUntil DateTime? // dunning grace window before suspension
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  plan          Plan?                 @relation(fields: [planId], references: [id])
  members       OrganizationMember[]
  stores        Store[]
  auditLogs     AuditLog[]
  subscriptions Subscription[]
  usageRecords  UsageRecord[]
  invoices      Invoice[]
  invitations   Invitation[]
  verification  MerchantVerification?
}

model MerchantVerification {
  id                 String             @id @default(cuid())
  organizationId     String             @unique
  status             VerificationStatus @default(PENDING)
  legalName          String
  businessType       String
  registrationNumber String?
  contactName        String
  contactPhone       String?
  address            String?
  documents          Json               @default("[]") // [{type,name,url}]
  rejectionReason    String?
  submittedAt        DateTime           @default(now())
  reviewedAt         DateTime?
  reviewedByUserId   String?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([status])
}

model Invitation {
  id              String     @id @default(cuid())
  organizationId  String
  email           String
  role            MemberRole @default(ANALYST)
  token           String     @unique
  status          String     @default("pending") // pending | accepted | revoked
  invitedByUserId String?
  createdAt       DateTime   @default(now())
  expiresAt       DateTime

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([email])
}

model OrganizationMember {
  id             String     @id @default(cuid())
  organizationId String
  userId         String
  role           MemberRole @default(OWNER)
  createdAt      DateTime   @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
}

// ---------------------------------------------------------------------------
// Stores, branding, credentials
// ---------------------------------------------------------------------------

model Store {
  id             String   @id
  organizationId String
  name           String
  liveMode       Boolean  @default(false) // false until production is activated
  feeBps         Int      @default(0) // settlement fee in basis points (100 = 1%)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization         Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branding             StoreBranding?
  apiKeys              ApiKey[]
  payments             Payment[]
  providerCredentials  ProviderCredential[]
  webhookEndpoints     WebhookEndpoint[]
  settlements          Settlement[]
  branches             Branch[]
  customers            Customer[]
  loyaltyProgram       LoyaltyProgram?
  loyaltyTiers         LoyaltyTier[]
  rewards              Reward[]
  redemptions          Redemption[]
  segments             Segment[]
  promotions           Promotion[]
  referralProgram      ReferralProgram?
  telegramConfig       TelegramConfig?
  notificationChannels NotificationChannel[]
  games                Game[]
  revenueShares        RevenueShareAgreement[]
  riskCases            RiskCase[]
  connectors           Connector[]

  @@index([organizationId])
}

model Branch {
  id        String   @id
  storeId   String
  name      String
  code      String?
  address   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store    Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  payments Payment[]

  @@unique([storeId, code])
  @@index([storeId])
}

model Customer {
  id                   String   @id
  storeId              String
  name                 String?
  email                String?
  phone                String?
  externalId           String? // the merchant's own customer id
  metadata             Json     @default("{}")
  pointsBalance        Int      @default(0)
  lifetimePoints       Int      @default(0) // cumulative earned; drives tier (never decremented)
  tierId               String?
  referralCode         String? // this customer's own referral code
  referredByCustomerId String? // who referred this customer
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  store        Store                @relation(fields: [storeId], references: [id], onDelete: Cascade)
  payments     Payment[]
  pointsLedger PointsTransaction[]
  redemptions  Redemption[]
  tier         LoyaltyTier?         @relation(fields: [tierId], references: [id])
  preferences  CustomerPreference[]
  consentLogs  ConsentLog[]

  @@unique([storeId, externalId])
  @@unique([storeId, referralCode])
  @@index([storeId, email])
}

/// A customer's current opt-in state per communication channel.
model CustomerPreference {
  id         String   @id
  customerId String
  channel    String // email | sms | whatsapp | telegram | push | marketing
  optedIn    Boolean
  updatedAt  DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([customerId, channel])
}

/// Immutable audit trail of consent changes (who/when/how).
model ConsentLog {
  id         String   @id
  customerId String
  channel    String
  optedIn    Boolean
  source     String? // checkout | dashboard | api | import
  createdAt  DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId, createdAt])
}

model TelegramConfig {
  id            String   @id @default(cuid())
  storeId       String   @unique
  chatId        String?
  enabled       Boolean  @default(false)
  enabledEvents String[] @default([]) // empty = all events
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

/// Outbound message channel (WhatsApp / SMS / Signal) mirroring payment events.
model NotificationChannel {
  id            String                  @id @default(cuid())
  storeId       String
  channel       NotificationChannelType
  destination   String? // phone number / signal recipient
  enabled       Boolean                 @default(false)
  enabledEvents String[]                @default([]) // empty = all events
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, channel])
  @@index([storeId])
}

model ReferralProgram {
  id                     String   @id @default(cuid())
  storeId                String   @unique
  active                 Boolean  @default(false)
  referrerPoints         Int      @default(0)
  refereePoints          Int      @default(0)
  // Affiliate commission: the referrer earns commissionBps (basis points) of
  // every paid payment their referees make. 0 = no commission. When
  // commissionDurationDays is set, commission only accrues within that many
  // days of the referral being created (null = lifetime).
  commissionBps          Int      @default(0)
  commissionDurationDays Int?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

enum CommissionStatus {
  ACCRUED
  HELD // accrued but withheld from payout (fraud review)
  PAID
  VOID
}

/// A commission accrued to a referrer on one of their referee's paid payments.
model ReferralCommission {
  id                 String           @id
  storeId            String
  referralId         String
  referrerCustomerId String
  paymentId          String           @unique // one commission per payment (idempotent)
  amount             Decimal          @db.Decimal(18, 2)
  currency           String
  bps                Int
  status             CommissionStatus @default(ACCRUED)
  createdAt          DateTime         @default(now())
  paidAt             DateTime?
  payoutRef          String?

  @@index([storeId, status])
  @@index([referrerCustomerId])
  @@index([referralId])
}

// ---------------------------------------------------------------------------
// Promotional games (Domain 9): a prize engine with weighted draws + inventory.
// ---------------------------------------------------------------------------

model Game {
  id               String   @id
  storeId          String
  name             String
  type             GameType
  active           Boolean  @default(false)
  // Auto-issue a play when a paid payment meets the threshold (scratch cards).
  autoIssue        Boolean  @default(false)
  minPaymentAmount Decimal? @db.Decimal(18, 2)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  store  Store      @relation(fields: [storeId], references: [id], onDelete: Cascade)
  prizes Prize[]
  plays  GamePlay[]

  @@index([storeId])
}

model Prize {
  id          String    @id
  gameId      String
  label       String
  type        PrizeType @default(NONE)
  pointsValue Int       @default(0) // when type = POINTS
  rewardId    String? // when type = REWARD (a loyalty Reward)
  weight      Int       @default(1) // relative probability weight (>=0)
  stock       Int       @default(-1) // -1 = unlimited
  awarded     Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  game  Game       @relation(fields: [gameId], references: [id], onDelete: Cascade)
  plays GamePlay[]

  @@index([gameId])
}

model GamePlay {
  id         String         @id
  gameId     String
  storeId    String
  customerId String?
  prizeId    String?
  status     GamePlayStatus @default(REVEALED)
  won        Boolean        @default(false)
  paymentId  String? // the payment that earned this play (auto-issue idempotency)
  createdAt  DateTime       @default(now())
  revealedAt DateTime?

  game  Game   @relation(fields: [gameId], references: [id], onDelete: Cascade)
  prize Prize? @relation(fields: [prizeId], references: [id])

  @@unique([gameId, paymentId]) // one auto-issued play per payment per game
  @@index([gameId])
  @@index([customerId])
  @@index([storeId, status])
}

model Referral {
  id                   String         @id
  storeId              String
  referrerCustomerId   String
  refereeCustomerId    String         @unique // a customer is referred at most once
  code                 String
  status               ReferralStatus @default(PENDING)
  rewardPointsReferrer Int            @default(0)
  rewardPointsReferee  Int            @default(0)
  // Fraud screening: when riskFlags is non-empty the referral is held —
  // points reward is withheld and commissions accrue as HELD (excluded from
  // payout) until a merchant clears or voids it.
  flagged              Boolean        @default(false)
  riskFlags            String[]       @default([])
  reviewedAt           DateTime?
  createdAt            DateTime       @default(now())
  rewardedAt           DateTime?

  @@index([storeId])
  @@index([referrerCustomerId])
  @@index([storeId, flagged])
}

model Reward {
  id          String   @id
  storeId     String
  name        String
  description String?
  pointsCost  Int
  stock       Int      @default(-1) // -1 = unlimited
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  store       Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)
  redemptions Redemption[]

  @@index([storeId])
}

model Redemption {
  id          String           @id
  storeId     String
  customerId  String
  rewardId    String
  pointsSpent Int
  code        String           @unique
  status      RedemptionStatus @default(ISSUED)
  createdAt   DateTime         @default(now())
  fulfilledAt DateTime?

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  reward   Reward   @relation(fields: [rewardId], references: [id], onDelete: Cascade)
  store    Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([storeId, status])
}

model LoyaltyTier {
  id             String   @id
  storeId        String
  name           String
  threshold      Int // lifetime points required to reach this tier
  earnMultiplier Decimal  @default(1) @db.Decimal(6, 2)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  store     Store      @relation(fields: [storeId], references: [id], onDelete: Cascade)
  customers Customer[]

  @@index([storeId, threshold])
}

model Segment {
  id          String   @id
  storeId     String
  name        String
  description String?
  rules       Json     @default("{}") // structured filter (see SegmentRules)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
}

model Promotion {
  id                   String          @id
  storeId              String
  name                 String
  type                 PromotionType
  status               PromotionStatus @default(DRAFT)
  segmentId            String? // null = all customers
  config               Json            @default("{}") // { multiplier?, bonusPoints?, minAmount? }
  budgetPoints         Int? // cap on total bonus points; null = unlimited
  spentPoints          Int             @default(0)
  startAt              DateTime?
  endAt                DateTime?
  submittedForApproval Boolean         @default(false)
  approved             Boolean         @default(false)
  approvedByUserId     String?
  approvalNote         String?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId, status])
}

model LoyaltyProgram {
  id            String   @id @default(cuid())
  storeId       String   @unique
  active        Boolean  @default(false)
  pointsPerUnit Decimal  @default(1) @db.Decimal(12, 4) // points earned per 1 unit of payment currency
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

model PointsTransaction {
  id         String        @id
  storeId    String
  customerId String
  type       PointsTxnType
  points     Int // signed: + for earn/adjust-up, - for redeem
  paymentId  String?
  reason     String?
  createdAt  DateTime      @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId, createdAt])
  @@index([paymentId])
}

model StoreBranding {
  id            String   @id @default(cuid())
  storeId       String   @unique
  displayName   String?
  logoUrl       String?
  primaryColor  String   @default("#1E5BD6") // PayKH brand blue
  supportEmail  String?
  successUrl    String?
  failureUrl    String?
  customMessage String?
  updatedAt     DateTime @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

/// Encrypted payment-provider credentials (AES-256-GCM). The `secretCiphertext`
/// column never holds plaintext.
model ProviderCredential {
  id               String   @id @default(cuid())
  storeId          String
  provider         String   @default("bakong")
  mode             KeyMode  @default(TEST)
  label            String?
  secretCiphertext String   @db.Text
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, provider, mode])
}

// ---------------------------------------------------------------------------
// API keys (hashed at rest)
// ---------------------------------------------------------------------------

model ApiKey {
  id            String    @id
  storeId       String
  mode          KeyMode
  label         String?
  tokenHash     String    @unique // SHA-256 of the full secret
  displayPrefix String // e.g. bk_live_ab12
  last4         String
  scopes        String[]  @default([])
  lastUsedAt    DateTime?
  revokedAt     DateTime?
  createdAt     DateTime  @default(now())

  store    Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  payments Payment[]

  @@index([storeId])
  @@index([tokenHash])
}

// ---------------------------------------------------------------------------
// Payments
// ---------------------------------------------------------------------------

model Payment {
  id             String        @id
  storeId        String
  apiKeyId       String?
  mode           KeyMode
  status         PaymentStatus @default(PENDING)
  amount         Decimal       @db.Decimal(20, 4)
  currency       Currency
  referenceId    String?
  description    String?
  metadata       Json          @default("{}")
  qrString       String        @db.Text
  refundedAmount Decimal       @default(0) @db.Decimal(20, 4)
  settlementId   String?
  branchId       String?
  customerId     String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  expiresAt      DateTime
  paidAt         DateTime?

  store             Store                     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  apiKey            ApiKey?                   @relation(fields: [apiKeyId], references: [id])
  statusHistory     PaymentStatusHistory[]
  providerReference PaymentProviderReference?
  webhookEvents     WebhookEvent[]
  refunds           Refund[]
  settlement        Settlement?               @relation(fields: [settlementId], references: [id])
  branch            Branch?                   @relation(fields: [branchId], references: [id])
  customer          Customer?                 @relation(fields: [customerId], references: [id])

  @@index([storeId, status])
  @@index([storeId, referenceId])
  @@index([storeId, createdAt])
}

model Refund {
  id            String       @id
  paymentId     String
  amount        Decimal      @db.Decimal(20, 4)
  currency      Currency
  reason        String?
  status        RefundStatus @default(SUCCEEDED)
  providerRefId String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([paymentId])
}

/// One AI Copilot invocation — for cost management, evaluation, and audit.
model AiUsageLog {
  id           String   @id
  storeId      String?
  feature      String // marketing_copy | campaign | analytics_summary | fraud_insights | assistant
  model        String
  source       String // ai | fallback | blocked
  inputTokens  Int      @default(0)
  outputTokens Int      @default(0)
  costCents    Int      @default(0) // estimated, in hundredths of a cent for precision
  blockedFor   String? // guardrail reason when source = blocked
  createdAt    DateTime @default(now())

  @@index([storeId, createdAt])
  @@index([feature])
}

// ---------------------------------------------------------------------------
// Double-entry ledger (Domain 13 — financial assurance). Append-only: journals
// and entries are never updated or deleted; corrections are new balancing
// journals. Every JournalEntry's lines sum to zero (debits == credits).
// ---------------------------------------------------------------------------

model LedgerAccount {
  code    String            @id // e.g. settlement_clearing, merchant_payable, fee_revenue
  name    String
  type    LedgerAccountType
  entries LedgerEntry[]
}

/// A balanced financial transaction (its lines sum debits == credits).
model JournalEntry {
  id        String        @id
  storeId   String?
  event     String // payment.captured | payment.refunded | commission.accrued | commission.paid
  reference String? // paymentId / commissionId — with `event` gives idempotency
  currency  String
  createdAt DateTime      @default(now())
  lines     LedgerEntry[]

  @@unique([event, reference])
  @@index([storeId, createdAt])
}

/// A single debit or credit line within a journal.
model LedgerEntry {
  id          String          @id
  journalId   String
  accountCode String
  storeId     String?
  direction   LedgerDirection
  amount      Decimal         @db.Decimal(20, 4)
  currency    String
  createdAt   DateTime        @default(now())

  journal JournalEntry  @relation(fields: [journalId], references: [id], onDelete: Cascade)
  account LedgerAccount @relation(fields: [accountCode], references: [code])

  @@index([accountCode, currency])
  @@index([storeId])
  @@index([journalId])
}

/// An installed third-party connector (Slack / Zapier / generic webhook) that
/// receives payment events. Distinct from developer webhooks (signed, retried)
/// — these are simple fire-and-forget app integrations.
model Connector {
  id            String        @id
  storeId       String
  type          ConnectorType
  targetUrl     String
  enabled       Boolean       @default(true)
  enabledEvents String[]      @default([])
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
}

/// A risk/fraud review case raised by the risk-scoring engine or manually.
model RiskCase {
  id         String         @id
  storeId    String
  paymentId  String?
  customerId String?
  score      Int // 0-100
  reasons    String[]       @default([])
  status     RiskCaseStatus @default(OPEN)
  resolution String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId, status])
  @@index([paymentId])
}

/// A partner's revenue-share on a store's platform processing fees.
model RevenueShareAgreement {
  id          String   @id
  storeId     String
  partnerName String
  shareBps    Int // basis points of the store's processing fees the partner earns
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
}

model Settlement {
  id           String           @id
  storeId      String
  currency     Currency
  payoutDate   DateTime // the UTC day being settled
  status       SettlementStatus @default(SETTLED)
  grossAmount  Decimal          @db.Decimal(20, 4)
  refundAmount Decimal          @db.Decimal(20, 4)
  feeBps       Int              @default(0)
  feeAmount    Decimal          @db.Decimal(20, 4)
  netAmount    Decimal          @db.Decimal(20, 4)
  paymentCount Int              @default(0)
  createdAt    DateTime         @default(now())
  settledAt    DateTime?

  store    Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  payments Payment[]

  @@unique([storeId, currency, payoutDate])
  @@index([storeId, payoutDate])
}

model ReconciliationReport {
  id            String   @id
  storeId       String?
  provider      String
  periodStart   DateTime
  periodEnd     DateTime
  checked       Int      @default(0)
  matched       Int      @default(0)
  mismatched    Int      @default(0)
  discrepancies Json     @default("[]")
  createdAt     DateTime @default(now())

  @@index([storeId, createdAt])
}

model PaymentStatusHistory {
  id         String         @id @default(cuid())
  paymentId  String
  fromStatus PaymentStatus?
  toStatus   PaymentStatus
  reason     String?
  createdAt  DateTime       @default(now())

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([paymentId])
}

model PaymentProviderReference {
  id            String   @id @default(cuid())
  paymentId     String   @unique
  provider      String   @default("bakong")
  md5           String? // KHQR md5 hash used to poll Bakong
  billNumber    String?
  providerTxnId String?
  rawResponse   Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
}

// ---------------------------------------------------------------------------
// Idempotency
// ---------------------------------------------------------------------------

model IdempotencyRecord {
  id             String   @id @default(cuid())
  storeId        String
  endpoint       String // e.g. "POST /v1/payments"
  idempotencyKey String
  requestHash    String // SHA-256 of the canonical request body
  responseStatus Int
  responseBody   Json
  createdAt      DateTime @default(now())
  expiresAt      DateTime

  @@unique([storeId, endpoint, idempotencyKey])
  @@index([expiresAt])
}

// ---------------------------------------------------------------------------
// Webhooks (schema defined in Phase 1; delivery worker wired in Phase 2)
// ---------------------------------------------------------------------------

model WebhookEndpoint {
  id            String   @id @default(cuid())
  storeId       String
  url           String
  enabledEvents String[] @default([])
  disabled      Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  store      Store             @relation(fields: [storeId], references: [id], onDelete: Cascade)
  secrets    WebhookSecret[]
  deliveries WebhookDelivery[]

  @@index([storeId])
}

model WebhookSecret {
  id         String    @id @default(cuid())
  endpointId String
  secret     String // whsec_...
  active     Boolean   @default(true)
  createdAt  DateTime  @default(now())
  expiresAt  DateTime?

  endpoint WebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)

  @@index([endpointId])
}

model WebhookEvent {
  id        String   @id
  storeId   String
  paymentId String?
  type      String
  payload   Json
  createdAt DateTime @default(now())

  payment    Payment?          @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  deliveries WebhookDelivery[]

  @@index([storeId])
}

model WebhookDelivery {
  id             String                @id
  endpointId     String
  eventId        String
  status         WebhookDeliveryStatus @default(PENDING)
  attempt        Int                   @default(0)
  responseStatus Int?
  responseBody   String?               @db.Text
  error          String?
  nextAttemptAt  DateTime?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  endpoint WebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)
  event    WebhookEvent    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([endpointId])
  @@index([status, nextAttemptAt])
}

// ---------------------------------------------------------------------------
// Plans, billing, usage (schema in Phase 1; behavior in Phase 3)
// ---------------------------------------------------------------------------

model Plan {
  id               String   @id
  name             String
  monthlyPaidQuota Int // successful payments per month; -1 = unlimited
  priceUsdCents    Int      @default(0)
  createdAt        DateTime @default(now())

  organizations Organization[]
  subscriptions Subscription[]
}

model Subscription {
  id             String             @id @default(cuid())
  organizationId String
  planId         String
  status         SubscriptionStatus @default(ACTIVE)
  periodStart    DateTime
  periodEnd      DateTime
  createdAt      DateTime           @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plan         Plan         @relation(fields: [planId], references: [id])

  @@index([organizationId])
}

model UsageRecord {
  id              String   @id @default(cuid())
  organizationId  String
  storeId         String?
  periodStart     DateTime
  paidCount       Int      @default(0)
  lastWarnedLevel Int      @default(0) // highest quota-warning threshold emailed (70/90/100)
  updatedAt       DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, periodStart])
}

model Invoice {
  id             String    @id @default(cuid())
  organizationId String
  planId         String?
  amountUsdCents Int
  status         String    @default("draft") // draft | open | paid | void
  periodStart    DateTime
  periodEnd      DateTime
  dueAt          DateTime?
  paidAt         DateTime?
  qrString       String?   @db.Text // platform subscription KHQR (separate ledger)
  md5            String? // for provider status polling
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([status])
}

// ---------------------------------------------------------------------------
// Audit & security (append-only)
// ---------------------------------------------------------------------------

model AuditLog {
  id             String   @id @default(cuid())
  organizationId String?
  storeId        String?
  actorUserId    String?
  action         String
  entity         String?
  beforeValue    Json?
  afterValue     Json?
  ipAddress      String?
  userAgent      String?
  requestId      String?
  createdAt      DateTime @default(now())

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  actor        User?         @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
}

model SecurityEvent {
  id        String   @id @default(cuid())
  type      String // e.g. "auth.failed", "apikey.invalid", "rate_limited"
  storeId   String?
  ipAddress String?
  userAgent String?
  detail    Json?
  requestId String?
  createdAt DateTime @default(now())

  @@index([type, createdAt])
}
