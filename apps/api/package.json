  "private": true,
  "description": "PayKH REST API (NestJS)",
  "license": "Apache-2.0",
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "start:prod": "node dist/main.js",
    "lint": "eslint \"src/**/*.ts\" --max-warnings 0",
    "test": "jest",
    "test:e2e": "jest --config test/jest-e2e.json",
